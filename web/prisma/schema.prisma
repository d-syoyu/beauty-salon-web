generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id @default(cuid())
  name             String?
  email            String?         @unique
  emailVerified    DateTime?
  image            String?
  phone            String?
  password         String?
  role             String          @default("CUSTOMER")
  newsletterOptOut Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accounts         Account[]
  kartes           CustomerKarte[]
  reservations     Reservation[]
  createdSales     Sale[]          @relation("CreatedSales")
  dailyClosings    DailyClosing[]  @relation("DailyClosingClosedBy")
  monthlyClosings  MonthlyClosing[] @relation("MonthlyClosingClosedBy")
  sales            Sale[]
  sessions         Session[]
}

model Shop {
  id                       String             @id @default(cuid())
  name                     String
  publicSlug               String?            @unique
  address                  String?
  phoneNumber              String?
  description              String?
  accessInfo               String?
  coverImageUrl            String?
  googleBusinessLocationId String?
  isPublished              Boolean            @default(true)
  isActive                 Boolean            @default(true)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  businessHours            ShopBusinessHour[]
  reservations             Reservation[]
  holidays                 Holiday[]
  specialOpenDays          SpecialOpenDay[]
  sales                    Sale[]
  paymentMethods           PaymentMethodSetting[]
  staffShops               StaffShop[]
  categoryShops            CategoryShop[]
  menuShops                MenuShop[]
  productShops             ProductShop[]
  couponShops              CouponShop[]
  announcements            Announcement[]
  galleryPhotos            GalleryPhoto[]
  dailyClosings            DailyClosing[]
  monthlyClosings          MonthlyClosing[]

  @@index([isActive])
  @@index([isPublished])
}

model ShopBusinessHour {
  id                   String   @id @default(cuid())
  shopId               String
  dayOfWeek            Int
  isOpen               Boolean  @default(true)
  openTime             String
  closeTime            String
  lastBookingOffsetMin Int      @default(60)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  shop                 Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, dayOfWeek])
  @@index([shopId, dayOfWeek])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Reservation {
  id                    String            @id @default(cuid())
  userId                String
  shopId                String?
  couponId              String?
  couponCode            String?
  couponDiscount        Int               @default(0)
  totalPrice            Int
  totalDuration         Int
  menuSummary           String
  date                  DateTime
  startTime             String
  endTime               String
  status                String            @default("CONFIRMED")
  paymentMethod         String            @default("ONSITE")
  stripePaymentIntentId String?
  note                  String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  staffId               String?
  staffName             String?
  isFirstVisit          Boolean?
  coupon                Coupon?           @relation(fields: [couponId], references: [id])
  shop                  Shop?             @relation(fields: [shopId], references: [id])
  staff                 Staff?            @relation(fields: [staffId], references: [id])
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                 ReservationItem[]
  sale                  Sale?

  @@index([date])
  @@index([userId])
  @@index([status])
  @@index([date, status])
  @@index([couponId])
  @@index([staffId])
  @@index([shopId])
  @@index([shopId, date])
}

model ReservationItem {
  id            String      @id @default(cuid())
  reservationId String
  menuId        String
  menuName      String
  category      String
  price         Int
  duration      Int
  orderIndex    Int
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([reservationId, orderIndex])
  @@index([reservationId])
}

model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  nameEn       String
  color        String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  menus        Menu[]
  shops        CategoryShop[]

  @@index([isActive])
}

model Menu {
  id               String      @id @default(cuid())
  name             String
  categoryId       String
  price            Int
  priceVariable    Boolean     @default(false)
  duration         Int
  lastBookingTime  String
  displayOrder     Int         @default(0)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  category         Category    @relation(fields: [categoryId], references: [id])
  staffAssignments StaffMenu[]
  shops            MenuShop[]

  @@index([categoryId])
  @@index([isActive])
}

model Holiday {
  id        String   @id @default(cuid())
  shopId    String?
  date      DateTime
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
  shop      Shop?    @relation(fields: [shopId], references: [id])

  @@unique([shopId, date, startTime, endTime])
  @@index([date])
  @@index([shopId, date])
}

model SpecialOpenDay {
  id        String   @id @default(cuid())
  shopId    String?
  date      DateTime
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
  shop      Shop?    @relation(fields: [shopId], references: [id])

  @@unique([shopId, date, startTime, endTime])
  @@index([date])
  @@index([shopId, date])
}

model Sale {
  id             String         @id @default(cuid())
  saleNumber     String         @unique
  userId         String?
  shopId         String?
  customerName   String?
  customerPhone  String?
  reservationId  String?        @unique
  subtotal       Int
  taxAmount      Int
  taxRate        Int
  discountAmount Int            @default(0)
  couponId       String?
  couponDiscount Int            @default(0)
  totalAmount    Int
  paymentMethod  String
  paymentStatus  String         @default("PENDING")
  saleDate       DateTime
  saleTime       String
  note           String?
  createdBy      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  cancelReason   String?
  cancelledAt    DateTime?
  isNominated    Boolean        @default(false)
  refundAmount   Int            @default(0)
  refundedAt     DateTime?
  staffId        String?
  staffName      String?
  karte          CustomerKarte?
  payments       Payment[]
  coupon         Coupon?        @relation(fields: [couponId], references: [id])
  createdByUser  User?          @relation("CreatedSales", fields: [createdBy], references: [id])
  reservation    Reservation?   @relation(fields: [reservationId], references: [id])
  shop           Shop?          @relation(fields: [shopId], references: [id])
  staff          Staff?         @relation(fields: [staffId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])
  auditLogs      SaleAuditLog[]
  items          SaleItem[]

  @@index([saleDate])
  @@index([userId])
  @@index([reservationId])
  @@index([couponId])
  @@index([paymentMethod])
  @@index([staffId])
  @@index([createdAt])
  @@index([shopId])
  @@index([shopId, saleDate])
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  itemType    String
  menuId      String?
  menuName    String?
  categoryId  String?
  category    String?
  duration    Int?
  productId   String?
  productName String?
  quantity    Int     @default(1)
  unitPrice   Int
  subtotal    Int
  orderIndex  Int
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([saleId, orderIndex])
  @@index([saleId])
  @@index([categoryId])
}

model Payment {
  id            String   @id @default(cuid())
  saleId        String
  paymentMethod String
  amount        Int
  orderIndex    Int
  note          String?
  createdAt     DateTime @default(now())
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([saleId, orderIndex])
  @@index([saleId])
}

model Coupon {
  id                    String        @id @default(cuid())
  code                  String        @unique
  name                  String
  type                  String
  value                 Int
  description           String?
  applicableMenuIds     String        @default("[]")
  applicableCategoryIds String        @default("[]")
  applicableWeekdays    String        @default("[]")
  startTime             String?
  endTime               String?
  onlyFirstTime         Boolean       @default(false)
  onlyReturning         Boolean       @default(false)
  validFrom             DateTime
  validUntil            DateTime
  usageLimit            Int?
  usageLimitPerCustomer Int?
  usageCount            Int           @default(0)
  minimumAmount         Int?
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  shops                 CouponShop[]
  usages                CouponUsage[]
  reservations          Reservation[]
  sales                 Sale[]

  @@index([code])
  @@index([isActive])
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String
  saleId     String?  @unique
  customerId String?
  usedAt     DateTime @default(now())
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([customerId])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PaymentMethodSetting {
  id                     String   @id @default(cuid())
  shopId                 String?
  channel                String   @default("IN_STORE")
  code                   String   @unique
  displayName            String
  provider               String?
  terminalName           String?
  note                   String?
  isActive               Boolean  @default(true)
  isVisibleOnStorefront  Boolean  @default(true)
  displayOrder           Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  shop                   Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([code])
  @@index([shopId, isActive])
  @@index([channel, isActive])
}

model Staff {
  id                 String                        @id @default(cuid())
  name               String
  nameEn             String?
  role               String
  image              String?
  bio                String?
  specialties        String                        @default("[]")
  experience         String?
  socialMedia        String                        @default("{}")
  displayOrder       Int                           @default(0)
  isActive           Boolean                       @default(true)
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  approvalLogs       ApprovalActionLog[]
  correctionRequests AttendanceCorrectionRequest[]
  monthlyClosures    AttendanceMonthlyClosure[]
  attendanceRecords  AttendanceRecord[]
  kartes             CustomerKarte[]
  leaveGrants        LeaveGrant[]
  leaveRequests      LeaveRequest[]
  overtimeRequests   OvertimeRequest[]
  reservations       Reservation[]
  sales              Sale[]
  shiftPatterns      ShiftPattern[]
  employmentProfile  StaffEmploymentProfile?
  menuAssignments    StaffMenu[]
  shops              StaffShop[]
  schedules          StaffSchedule[]
  scheduleOverrides  StaffScheduleOverride[]

  @@index([isActive])
}

model StaffSchedule {
  id        String   @id @default(cuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
}

model StaffScheduleOverride {
  id           String    @id @default(cuid())
  staffId      String
  date         DateTime
  startTime    String?
  endTime      String?
  createdAt    DateTime  @default(now())
  breakMinutes Int       @default(0)
  note         String?
  patternCode  String?
  publishedAt  DateTime?
  source       String    @default("manual")
  status       String    @default("scheduled")
  updatedAt    DateTime  @updatedAt
  timeSegments Json?
  staff        Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
  @@index([status])
}

model StaffMenu {
  id      String @id @default(cuid())
  staffId String
  menuId  String
  menu    Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, menuId])
  @@index([staffId])
  @@index([menuId])
}

model StaffShop {
  staffId   String
  shopId    String
  isPrimary Boolean @default(false)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([staffId, shopId])
  @@index([staffId])
  @@index([shopId])
}

model CategoryShop {
  categoryId String
  shopId     String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([categoryId, shopId])
  @@index([categoryId])
  @@index([shopId])
}

model MenuShop {
  menuId  String
  shopId  String
  menu    Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  shop    Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([menuId, shopId])
  @@index([menuId])
  @@index([shopId])
}

model CouponShop {
  couponId String
  shopId   String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  shop     Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([couponId, shopId])
  @@index([couponId])
  @@index([shopId])
}

model ShiftPattern {
  id           String   @id @default(cuid())
  staffId      String
  code         String
  name         String
  startTime    String
  endTime      String
  breakMinutes Int      @default(0)
  color        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  staff        Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, code])
  @@index([staffId])
  @@index([isActive])
}

model LeavePolicy {
  id                 String                   @id @default(cuid())
  name               String
  grantMode          String                   @default("hire_date")
  fixedGrantMonth    Int?
  fixedGrantDay      Int?
  isActive           Boolean                  @default(true)
  notes              String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  leaveGrants        LeaveGrant[]
  employmentProfiles StaffEmploymentProfile[]

  @@index([isActive])
}

model StaffEmploymentProfile {
  id                   String       @id @default(cuid())
  staffId              String       @unique
  hireDate             DateTime?
  employmentType       String       @default("full_time")
  prescribedWeeklyDays Int?
  prescribedAnnualDays Int?
  leavePolicyId        String?
  warningNote          String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  leavePolicy          LeavePolicy? @relation(fields: [leavePolicyId], references: [id])
  staff                Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([leavePolicyId])
}

model LeaveType {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  unit           String         @default("full")
  deductsBalance Boolean        @default(true)
  color          String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  leaveGrants    LeaveGrant[]
  leaveRequests  LeaveRequest[]

  @@index([isActive])
}

model LeaveGrant {
  id                        String       @id @default(cuid())
  staffId                   String
  leavePolicyId             String?
  leaveTypeId               String?
  grantDate                 DateTime
  expireDate                DateTime?
  grantedDays               Float
  usedDays                  Float        @default(0)
  remainingManualAdjustment Float        @default(0)
  source                    String       @default("auto")
  note                      String?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  leavePolicy               LeavePolicy? @relation(fields: [leavePolicyId], references: [id])
  leaveType                 LeaveType?   @relation(fields: [leaveTypeId], references: [id])
  staff                     Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([grantDate])
  @@index([expireDate])
}

model LeaveRequest {
  id               String    @id @default(cuid())
  staffId          String
  leaveTypeId      String
  date             DateTime
  unit             String    @default("full")
  startTime        String?
  endTime          String?
  requestedDays    Float     @default(1)
  status           String    @default("submitted")
  note             String?
  adminComment     String?
  approvedAt       DateTime?
  approvedByUserId String?
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  leaveType        LeaveType @relation(fields: [leaveTypeId], references: [id])
  staff            Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([date])
  @@index([status])
}

model AttendanceRecord {
  id                 String                        @id @default(cuid())
  staffId            String
  date               DateTime
  scheduledStartTime String?
  scheduledEndTime   String?
  actualStartTime    String?
  actualEndTime      String?
  totalWorkMinutes   Int                           @default(0)
  totalBreakMinutes  Int                           @default(0)
  lateMinutes        Int                           @default(0)
  earlyLeaveMinutes  Int                           @default(0)
  overtimeMinutes    Int                           @default(0)
  status             String                        @default("not_started")
  note               String?
  isClosed           Boolean                       @default(false)
  closedAt           DateTime?
  createdByUserId    String?
  updatedByUserId    String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  breaks             AttendanceBreak[]
  correctionRequests AttendanceCorrectionRequest[]
  staff              Staff                         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
  @@index([status])
}

model AttendanceBreak {
  id                 String           @id @default(cuid())
  attendanceRecordId String
  startTime          String
  endTime            String?
  startedAt          DateTime         @default(now())
  endedAt            DateTime?
  durationMinutes    Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)

  @@index([attendanceRecordId])
}

model AttendanceCorrectionRequest {
  id                    String            @id @default(cuid())
  staffId               String
  attendanceRecordId    String?
  date                  DateTime
  requestedStartTime    String?
  requestedEndTime      String?
  requestedBreakMinutes Int?
  requestCategory       String            @default("correction")
  status                String            @default("submitted")
  note                  String?
  adminComment          String?
  approvedAt            DateTime?
  approvedByUserId      String?
  createdByUserId       String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  attendanceRecord      AttendanceRecord? @relation(fields: [attendanceRecordId], references: [id])
  staff                 Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([date])
  @@index([status])
}

model OvertimeRequest {
  id                 String    @id @default(cuid())
  staffId            String
  date               DateTime
  requestedStartTime String?
  requestedEndTime   String
  requestCategory    String    @default("overtime")
  isHolidayWork      Boolean   @default(false)
  status             String    @default("submitted")
  note               String?
  adminComment       String?
  approvedAt         DateTime?
  approvedByUserId   String?
  createdByUserId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  staff              Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([date])
  @@index([status])
}

model ApprovalActionLog {
  id            String   @id @default(cuid())
  requestType   String
  requestId     String
  action        String
  actedByUserId String?
  comment       String?
  staffId       String?
  createdAt     DateTime @default(now())
  staff         Staff?   @relation(fields: [staffId], references: [id])

  @@index([requestType, requestId])
  @@index([staffId])
}

model AttendanceMonthlyClosure {
  id             String    @id @default(cuid())
  staffId        String
  year           Int
  month          Int
  status         String    @default("open")
  blockedReason  String?
  closedAt       DateTime?
  closedByUserId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  staff          Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, year, month])
  @@index([year, month])
  @@index([status])
}

model Product {
  id                     String        @id @default(cuid())
  name                   String
  categoryName           String
  unitPrice              Int
  stockQuantity          Int           @default(0)
  sku                    String?       @unique
  barcode                String?
  description            String?
  imageUrl               String?
  isActive               Boolean       @default(true)
  isVisibleOnStorefront  Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  shops                  ProductShop[]

  @@index([isActive])
  @@index([categoryName])
}

model ProductShop {
  productId String
  shopId    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([productId, shopId])
  @@index([productId])
  @@index([shopId])
}

model Announcement {
  id                    String         @id @default(cuid())
  shopId                String?
  title                 String
  body                  String
  imageUrl              String?
  channels              String[]
  status                String         @default("draft")
  publishedAt           DateTime?
  expiresAt             DateTime?
  targetCategoryIds     String         @default("[]")
  targetMenuIds         String         @default("[]")
  targetLastVisitMonths Int?
  targetMinVisitCount   Int?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  shop                  Shop?          @relation(fields: [shopId], references: [id], onDelete: SetNull)
  sends                 CampaignSend[]

  @@index([status])
  @@index([shopId, status])
  @@index([publishedAt])
}

model CampaignSend {
  id             String       @id @default(cuid())
  announcementId String
  channel        String
  sentAt         DateTime     @default(now())
  recipientCount Int
  successCount   Int          @default(0)
  errorCount     Int          @default(0)
  errorSample    String?
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([sentAt])
}

model GalleryPhoto {
  id           String   @id @default(cuid())
  shopId       String?
  imageUrl     String
  caption      String?
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([shopId, isPublished, displayOrder])
}

model DailyClosing {
  id               String   @id @default(cuid())
  shopId           String?
  date             DateTime @db.Date
  status           String   @default("open")
  totalSales       Int
  saleCount        Int
  totalTax         Int      @default(0)
  totalDiscount    Int      @default(0)
  paymentBreakdown Json     @default("{}")
  expectedCash     Int      @default(0)
  actualCash       Int?
  cashDifference   Int?
  note             String?
  closedAt         DateTime?
  closedByUserId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  shop             Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  closedBy         User?    @relation("DailyClosingClosedBy", fields: [closedByUserId], references: [id])

  @@unique([shopId, date])
  @@index([date])
  @@index([shopId, date])
  @@index([status])
}

model MonthlyClosing {
  id                 String   @id @default(cuid())
  shopId             String?
  year               Int
  month              Int
  status             String   @default("open")
  totalSales         Int
  saleCount          Int
  totalTax           Int      @default(0)
  totalDiscount      Int      @default(0)
  averagePerCustomer Int      @default(0)
  paymentBreakdown   Json     @default("{}")
  dailyClosingCount  Int      @default(0)
  note               String?
  closedAt           DateTime?
  closedByUserId     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  shop               Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  closedBy           User?    @relation("MonthlyClosingClosedBy", fields: [closedByUserId], references: [id])

  @@unique([shopId, year, month])
  @@index([year, month])
  @@index([shopId, year, month])
  @@index([status])
}

model CustomerKarte {
  id              String   @id @default(cuid())
  userId          String
  staffId         String?
  staffName       String?
  visitDate       DateTime
  treatmentNote   String?
  chemicalFormula String?
  hairCondition   String?
  photos          String   @default("[]")
  nextVisitNote   String?
  ngNotes         String?
  saleId          String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sale            Sale?    @relation(fields: [saleId], references: [id])
  staff           Staff?   @relation(fields: [staffId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([visitDate])
  @@index([staffId])
}

model SaleAuditLog {
  id           String   @id @default(cuid())
  saleId       String
  action       String
  changedField String?
  oldValue     String?
  newValue     String?
  reason       String?
  actedBy      String?
  createdAt    DateTime @default(now())
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([action])
}
